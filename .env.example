# ============================================
# SEO 블로그 템플릿 - 환경 변수 설정
# ============================================
# 이 파일을 복사해서 .env로 이름을 바꾸세요.
# Vercel 배포 시에는 Vercel 대시보드 → Settings → Environment Variables에 입력합니다.

# 1. 사이트 URL (배포 후 본인 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=https://example.com

# 2. Turso 데이터베이스 URL (turso.tech에서 생성)
#    예: libsql://your-db-name-username.turso.io
TURSO_DATABASE_URL=

# 3. Turso 인증 토큰 (turso.tech 대시보드에서 복사)
DATABASE_AUTH_TOKEN=

# 4. Gemini API 키 (aistudio.google.com에서 발급)
#    AI 콘텐츠 생성에 사용됩니다
GEMINI_API_KEY=

# 5. 관리자 비밀번호 (/admin 페이지 접근용)
#    기본값: coleitai1234 (반드시 변경하세요!)
ADMIN_PASSWORD=coleitai1234

# 6. Unsplash API 키 (unsplash.com/developers에서 발급, 선택)
UNSPLASH_ACCESS_KEY=

# 7. 크론 시크릿 (GitHub Actions 자동 발행용, 선택)
CRON_SECRET=

# ── 아래는 건드리지 마세요 ──────────────────────
# Prisma 내부용 (로컬 개발 시 SQLite 사용)
DATABASE_URL=file:./dev.db
